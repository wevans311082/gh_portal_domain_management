# Django
DJANGO_SECRET_KEY=your-very-long-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Startup automation (container entrypoint)
# AUTO_MAKEMIGRATIONS=1 will run `python manage.py makemigrations --noinput`
# before `migrate` on each container start.
AUTO_MAKEMIGRATIONS=0

# RUN_COLLECTSTATIC=1 will run collectstatic on startup.
# Usually 1 for web, 0 for celery/celery-beat.
RUN_COLLECTSTATIC=1

# Database
DATABASE_URL=postgres://grumpy:grumpy_pass@db:5432/grumpy_portal

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@grumpyhosting.co.uk
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=Grumpy Hosting <noreply@grumpyhosting.co.uk>

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# GoCardless
GOCARDLESS_ACCESS_TOKEN=your-gocardless-token
GOCARDLESS_ENVIRONMENT=sandbox

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# WHM/cPanel
WHM_HOST=your-whm-host.example.com
WHM_PORT=2087
WHM_USERNAME=root
WHM_API_TOKEN=your-whm-api-token

# ResellerClub (domains)
# Live API base URL: https://httpapi.com/api
# Test API base URL: https://test.httpapi.com/api
RESELLERCLUB_RESELLER_ID=your-reseller-id
RESELLERCLUB_CUSTOMER_ID=your-customer-id
RESELLERCLUB_API_KEY=your-api-key
RESELLERCLUB_API_URL=https://test.httpapi.com/api

# Cloudflare
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_EMAIL=your-cloudflare-email

# Companies House
COMPANIES_HOUSE_API_KEY=your-companies-house-api-key

# Sentry (optional)
SENTRY_DSN=

# Backup
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Site
SITE_DOMAIN=grumpyhosting.co.uk
SITE_NAME=Grumpy Hosting
